# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.openlingo.dev

# Database backend: "sqlite" (local dev) or "dynamodb" (prod)
DB_BACKEND=sqlite
SQLITE_PATH=local.db

# DynamoDB (only needed when DB_BACKEND=dynamodb)
# DYNAMODB_TABLE_PREFIX=lingo_
# AWS_REGION=us-east-1

# CORS — comma-separated origins
CORS_ORIGINS=["http://localhost:5173"]

DEBUG=true

# Default dev identity — used by the seed script (first user) and as the
# auth fallback when no X-Dev-User header or Bearer token is sent.
DEV_USER=dev|user-1

# Fix 4 — admin allow-list. Until OAuth scopes land, admin routes are gated
# by membership in this list. Accepts either internal UUIDs (preferred for
# prod) or Auth0 subs. JSON array; empty = nobody is admin via env.
# ADMIN_USER_IDS=["auth0|abc123","auth0|def456"]
ADMIN_USER_IDS=[]
